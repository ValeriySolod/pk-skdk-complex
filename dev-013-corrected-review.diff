+import test from 'node:test';
+import assert from 'node:assert/strict';
+import { ApiConfigurationError, ApiError } from '../../api/client.ts';
+import { InvalidRoleAssignmentsResponseError } from './roleAssignmentContract.ts';
+import { loadRoleAssignments, roleAssignmentsErrorMessages } from './roleAssignmentsState.ts';
+
+const roleAssignments = [{ id: 1 }];
+function dependencies(result) { let clearCount = 0; return { value: { readRoleAssignments: async () => { if (result instanceof Error) throw result; return result; }, clearSession: () => { clearCount += 1; } }, clearCount: () => clearCount }; }
+test('role assignments orchestration represents populated and empty success deterministically', async () => { assert.deepEqual(await loadRoleAssignments(dependencies(roleAssignments).value), { status: 'success', roleAssignments }); assert.deepEqual(await loadRoleAssignments(dependencies([]).value), { status: 'success', roleAssignments: [] }); });
+test('active role assignments 401 expires the session while stale 401 has no token side effect', async () => { const active = dependencies(new ApiError('Unauthorized', 'http', 401)); assert.deepEqual(await loadRoleAssignments(active.value), { status: 'expired-session' }); assert.equal(active.clearCount(), 1); const stale = dependencies(new ApiError('Unauthorized', 'http', 401)); assert.deepEqual(await loadRoleAssignments(stale.value, () => false), { status: 'expired-session' }); assert.equal(stale.clearCount(), 0); });
+test('403 and all other role assignments failures remain distinct and preserve the token', async () => { const cases = [[new ApiError('Forbidden', 'http', 403), 'forbidden'], [new InvalidRoleAssignmentsResponseError(), 'malformed-response'], [new ApiError('Network', 'network'), 'network'], [new ApiConfigurationError(), 'configuration'], [new ApiError('Server', 'http', 503), 'server'], [new ApiError('Conflict', 'http', 409), 'unexpected'], [new Error('Unknown'), 'unexpected']]; for (const [error, failure] of cases) { const setup = dependencies(error); assert.deepEqual(await loadRoleAssignments(setup.value), { status: 'error', failure }); assert.equal(setup.clearCount(), 0); assert.notEqual(roleAssignmentsErrorMessages[failure], ''); } });
