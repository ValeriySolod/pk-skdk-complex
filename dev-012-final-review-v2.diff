+function harness(loadState) { const states = []; let navigationCount = 0; const coordinator = createProfilesPageCoordinator({ applyState: (state) => states.push(state), navigateToLogin: () => { navigationCount += 1; }, loadState }); return { coordinator, states, navigationCount: () => navigationCount }; }
